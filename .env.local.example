# ============================================================
# O SEGREDO FUNGI — variáveis de ambiente
# Copie este arquivo para ".env.local" e preencha os valores.
# O ".env.local" NÃO vai para o Git (está no .gitignore).
# ============================================================

# --- WooCommerce headless (WordPress como back-end) ---
# Gere as chaves em: WordPress > WooCommerce > Configurações > Avançado > API REST
WOOCOMMERCE_URL=https://loja.osegredofungi.com.br
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Links das áreas culturais ---
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@thesecretfungi
NEXT_PUBLIC_SPOTIFY_URL=https://open.spotify.com/user/31vzbqtky667df374nyzc5tpmj3u
NEXT_PUBLIC_PATREON_URL=https://www.patreon.com/

# Enquanto as chaves do WooCommerce não estiverem preenchidas,
# o site usa o catálogo mock de lib/products.ts automaticamente.
